  m_Script: {fileID: 11500000, guid: a75bd0c3ec69425b8fb2e913f8568433, type: 3}
  m_Name: 04_Death_returns
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Dialogues.Scripts.DialogueConfig
  dialogues:
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 8fe230ad2e4439a4e9a803bd0abaed75, type: 3}
    dialogueText: "... \u042F \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B."
    dialogueTexts:
    - text: "... \u042F \u0437\u0430\u043A\u043E\u043D\u0447\u0438\u043B."
      language: 1
    - text: ... I'm finished.
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u0421\u043C\u0435\u0440\u0442\u044C"
    speakerNames:
    - text: "\u0421\u043C\u0435\u0440\u0442\u044C"
      language: 1
    - text: Death
      language: 2
    speakerIcon: {fileID: 21300000, guid: 1c6622693046ea845bc080110caecb67, type: 3}
    dialogueText: "\u0414\u0430, \u044F \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430.
      \u041E\u0442\u043B\u0438\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430.
      \u0421\u0438\u043B \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E,
      \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F
      \u0432 \u0441\u0432\u043E\u044E \u0434\u0435\u0440\u0435\u0432\u043D\u044E,
      \u044F \u0431\u0443\u0434\u0443 \u0436\u0434\u0430\u0442\u044C. "
    dialogueTexts:
    - text: "\u0414\u0430, \u044F \u043F\u043E\u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430.
        \u041E\u0442\u043B\u0438\u0447\u043D\u0430\u044F \u0440\u0430\u0431\u043E\u0442\u0430.
        \u0421\u0438\u043B \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E,
        \u043F\u043E\u044D\u0442\u043E\u043C\u0443 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439\u0441\u044F
        \u0432 \u0441\u0432\u043E\u044E \u0434\u0435\u0440\u0435\u0432\u043D\u044E,
        \u044F \u0431\u0443\u0434\u0443 \u0436\u0434\u0430\u0442\u044C. "
      language: 1
    - text: "Yes, I felt it. Excellent work. There's enough power, so head back to
        your village \u2014 I'll be waiting.  "
      language: 2
    delay: 0.04
    isLeft: 0
