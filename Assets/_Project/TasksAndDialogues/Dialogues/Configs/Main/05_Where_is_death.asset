    speakerIcon: {fileID: 21300000, guid: 9ef250b6e9917594489e9797a751b497, type: 3}
    dialogueText: "\u041D\u0435\u0443\u0436\u0435\u043B\u0438 \u043E\u043F\u0430\u0437\u0434\u044B\u0432\u0430\u0435\u0442..."
    dialogueTexts:
    - text: "\u041D\u0435\u0443\u0436\u0435\u043B\u0438 \u043E\u043F\u0430\u0437\u0434\u044B\u0432\u0430\u0435\u0442..."
