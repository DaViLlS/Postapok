  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a75bd0c3ec69425b8fb2e913f8568433, type: 3}
  m_Name: 08_Obnimashki
  m_EditorClassIdentifier: Assembly-CSharp::_Project.TasksAndDialogues.Dialogues.Scripts.DialogueConfig
  dialogues:
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 335ac7bae9748024fad07a85e3f7c6da, type: 3}
    dialogueText: "\u042F \u0442\u0430\u043A \u0441\u0438\u043B\u044C\u043D\u043E
      \u0441\u043A\u0443\u0447\u0430\u043B..."
    dialogueTexts:
    - text: "\u042F \u0442\u0430\u043A \u0441\u0438\u043B\u044C\u043D\u043E \u0441\u043A\u0443\u0447\u0430\u043B..."
      language: 1
    - text: I missed you so much...
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 0fcb37bef2f0d76468565a50dfda6682, type: 3}
    dialogueText: "\u0427\u0442\u043E\u0436, \u0442\u0435\u043F\u0435\u0440\u044C
      \u0431\u0443\u0434\u0435\u043C \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C
      \u0432\u043C\u0435\u0441\u0442\u0435. \u0422\u0430\u043A \u0431\u0443\u0434\u0435\u0442
      \u0433\u043E\u0440\u0430\u0437\u0434\u043E \u0432\u0435\u0441\u0435\u043B\u0435\u0435"
    dialogueTexts:
    - text: "\u0427\u0442\u043E\u0436, \u0442\u0435\u043F\u0435\u0440\u044C \u0431\u0443\u0434\u0435\u043C
        \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C \u0432\u043C\u0435\u0441\u0442\u0435.
        \u0422\u0430\u043A \u0431\u0443\u0434\u0435\u0442 \u0433\u043E\u0440\u0430\u0437\u0434\u043E
        \u0432\u0435\u0441\u0435\u043B\u0435\u0435"
      language: 1
    - text: Well, now we'll be working together. It'll be much more fun
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: cd72f33c11310624eaf0322015292e31, type: 3}
    dialogueText: "\u0421\u043C\u0435\u0440\u0442\u044C \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435
      \u043D\u0435 \u043F\u0440\u0438\u0434\u0451\u0442. \u041F\u043E\u0439\u0434\u0451\u043C
      \u0442\u043E\u0433\u0434\u0430 \u0434\u0435\u043B\u0430 \u0434\u0435\u043B\u0430\u0442\u044C"
    dialogueTexts:
    - text: "\u0421\u043C\u0435\u0440\u0442\u044C \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435
        \u043D\u0435 \u043F\u0440\u0438\u0434\u0451\u0442. \u041F\u043E\u0439\u0434\u0451\u043C
        \u0442\u043E\u0433\u0434\u0430 \u0434\u0435\u043B\u0430 \u0434\u0435\u043B\u0430\u0442\u044C"
      language: 1
    - text: Death probably won't come. Let's get some work done
      language: 2
    delay: 0.04
    isLeft: 1
