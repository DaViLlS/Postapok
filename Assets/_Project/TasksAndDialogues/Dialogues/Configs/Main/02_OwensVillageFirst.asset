%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a75bd0c3ec69425b8fb2e913f8568433, type: 3}
  m_Name: 02_OwensVillageFirst
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Dialogues.Scripts.DialogueConfig
  dialogues:
  - speakerName: "\u0421\u043C\u0435\u0440\u0442\u044C"
    speakerNames:
    - text: "\u0421\u043C\u0435\u0440\u0442\u044C"
      language: 1
    - text: Death
      language: 2
    speakerIcon: {fileID: 21300000, guid: 1c6622693046ea845bc080110caecb67, type: 3}
    dialogueText: "\u0416\u0443\u0442\u043A\u043E\u0435 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u043E."
    dialogueTexts:
    - text: "\u0416\u0443\u0442\u043A\u043E\u0435 \u043C\u0435\u0441\u0442\u0435\u0447\u043A\u043E."
      language: 1
    - text: Creepy place.
      language: 2
    delay: 0.04
    isLeft: 0
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 8fe230ad2e4439a4e9a803bd0abaed75, type: 3}
    dialogueText: "\u041F\u043E \u043B\u0435\u0433\u0447\u0435, \u044D\u0442\u043E
      \u043C\u043E\u044F \u0440\u043E\u0434\u043D\u0430\u044F \u0434\u0435\u0440\u0435\u0432\u043D\u044F."
    dialogueTexts:
    - text: "\u041F\u043E \u043B\u0435\u0433\u0447\u0435, \u044D\u0442\u043E \u043C\u043E\u044F
        \u0440\u043E\u0434\u043D\u0430\u044F \u0434\u0435\u0440\u0435\u0432\u043D\u044F."
      language: 1
    - text: Take it easy, this is my home village.
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u0421\u043C\u0435\u0440\u0442\u044C"
    speakerNames:
    - text: "\u0421\u043C\u0435\u0440\u0442\u044C"
      language: 1
    - text: Death
      language: 2
    speakerIcon: {fileID: 21300000, guid: 1c6622693046ea845bc080110caecb67, type: 3}
    dialogueText: "\u0422\u043E\u0433\u0434\u0430 \u0442\u0435\u0431\u0435 \u0441\u0442\u043E\u0438\u0442
      \u043F\u043E\u0437\u0430\u0431\u043E\u0442\u0438\u0442\u044C\u0441\u044F \u043E
      \u0435\u0451 \u0431\u0443\u0434\u0443\u0449\u0435\u043C \u0431\u043B\u0430\u0433\u043E\u043F\u043E\u043B\u0443\u0447\u0438\u0438,
      \u0430 \u0442\u043E \u0431\u0435\u0437 \u0441\u043B\u0451\u0437 \u0441\u0435\u0439\u0447\u0430\u0441
      \u043D\u0435 \u0432\u0437\u0433\u043B\u044F\u043D\u0435\u0448\u044C. "
    dialogueTexts:
    - text: "\u0422\u043E\u0433\u0434\u0430 \u0442\u0435\u0431\u0435 \u0441\u0442\u043E\u0438\u0442
        \u043F\u043E\u0437\u0430\u0431\u043E\u0442\u0438\u0442\u044C\u0441\u044F
        \u043E \u0435\u0451 \u0431\u0443\u0434\u0443\u0449\u0435\u043C \u0431\u043B\u0430\u0433\u043E\u043F\u043E\u043B\u0443\u0447\u0438\u0438,
        \u0430 \u0442\u043E \u0431\u0435\u0437 \u0441\u043B\u0451\u0437 \u0441\u0435\u0439\u0447\u0430\u0441
        \u043D\u0435 \u0432\u0437\u0433\u043B\u044F\u043D\u0435\u0448\u044C. "
      language: 1
    - text: Then you should take care of its future well-being, because right now
        it's a sorry sight.
      language: 2
    delay: 0.04
    isLeft: 0
  - speakerName: "\u0421\u043C\u0435\u0440\u0442\u044C"
    speakerNames:
    - text: "\u0421\u043C\u0435\u0440\u0442\u044C"
      language: 1
    - text: Death
      language: 2
    speakerIcon: {fileID: 21300000, guid: 1c6622693046ea845bc080110caecb67, type: 3}
    dialogueText: "\u0412 \u043E\u0431\u0449\u0435\u043C, \u044F \u0434\u0430\u043C
      \u0442\u0435\u0431\u0435 \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u043A\u0443
      \u043D\u0430 \u0434\u0435\u0440\u0435\u0432\u043D\u044E, \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
      \u0442\u0435\u0431\u0435 \u0441\u043B\u0435\u0434\u0443\u0435\u0442 \u043D\u0430\u0447\u0430\u0442\u044C."
    dialogueTexts:
    - text: "\u0412 \u043E\u0431\u0449\u0435\u043C, \u044F \u0434\u0430\u043C \u0442\u0435\u0431\u0435
        \u043E\u0440\u0438\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u043A\u0443
        \u043D\u0430 \u0434\u0435\u0440\u0435\u0432\u043D\u044E, \u0441 \u043A\u043E\u0442\u043E\u0440\u043E\u0439
        \u0442\u0435\u0431\u0435 \u0441\u043B\u0435\u0434\u0443\u0435\u0442 \u043D\u0430\u0447\u0430\u0442\u044C."
      language: 1
    - text: Anyway, I'll give you directions to the village where you should start.
      language: 2
    delay: 0.04
    isLeft: 0
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: cd72f33c11310624eaf0322015292e31, type: 3}
    dialogueText: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E. "
    dialogueTexts:
    - text: "\u041E\u0442\u043B\u0438\u0447\u043D\u043E. "
      language: 1
    - text: Great.
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 5826fba851ca78849bff0cc8e0ee8cf8, type: 3}
    dialogueText: ...
    dialogueTexts:
    - text: ...
      language: 1
    - text: ...
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 0fcb37bef2f0d76468565a50dfda6682, type: 3}
    dialogueText: "\u0410 \u0447\u0442\u043E \u043D\u0430\u0441\u0447\u0451\u0442
      \u043D\u0430\u0448\u0435\u0439 \u0441\u0434\u0435\u043B\u043A\u0438? \u041A\u043E\u0433\u0434\u0430
      \u0442\u044B \u0438\u0441\u043F\u043E\u043B\u043D\u0438\u0448\u044C \u0441\u0432\u043E\u044E
      \u0447\u0430\u0441\u0442\u044C?"
    dialogueTexts:
    - text: "\u0410 \u0447\u0442\u043E \u043D\u0430\u0441\u0447\u0451\u0442 \u043D\u0430\u0448\u0435\u0439
        \u0441\u0434\u0435\u043B\u043A\u0438? \u041A\u043E\u0433\u0434\u0430 \u0442\u044B
        \u0438\u0441\u043F\u043E\u043B\u043D\u0438\u0448\u044C \u0441\u0432\u043E\u044E
        \u0447\u0430\u0441\u0442\u044C?"
      language: 1
    - text: And what about our deal? When will you hold up your end?
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u0421\u043C\u0435\u0440\u0442\u044C"
    speakerNames:
    - text: "\u0421\u043C\u0435\u0440\u0442\u044C"
      language: 1
    - text: Death
      language: 2
    speakerIcon: {fileID: 21300000, guid: 1c6622693046ea845bc080110caecb67, type: 3}
    dialogueText: "\u041F\u043E\u043A\u0430 \u043D\u0435 \u043C\u043E\u0433\u0443.
      \u0411\u0430\u043B\u0430\u043D\u0441 \u0441\u043B\u0438\u0448\u043A\u043E\u043C
      \u043D\u0430\u0440\u0443\u0448\u0435\u043D \u0438 \u0441\u0438\u043B \u0443
      \u043C\u0435\u043D\u044F \u0445\u0432\u0430\u0442\u0438\u043B\u043E \u0442\u043E\u043B\u044C\u043A\u043E
      \u043D\u0430 \u0442\u0435\u0431\u044F. \u041D\u0430\u0447\u043D\u0438 \u043F\u043E\u043A\u0430
      \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0442\u044C \u0441\u0432\u043E\u044E
      \u0447\u0430\u0441\u0442\u044C \u0441\u0434\u0435\u043B\u043A\u0438 \u0438
      \u044F \u0434\u0430\u043C \u043E \u0441\u0435\u0431\u0435 \u0437\u043D\u0430\u0442\u044C,
      \u043A\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u0443 \u0433\u043E\u0442\u043E\u0432\u0430."
    dialogueTexts:
    - text: "\u041F\u043E\u043A\u0430 \u043D\u0435 \u043C\u043E\u0433\u0443. \u0411\u0430\u043B\u0430\u043D\u0441
        \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043D\u0430\u0440\u0443\u0448\u0435\u043D
        \u0438 \u0441\u0438\u043B \u0443 \u043C\u0435\u043D\u044F \u0445\u0432\u0430\u0442\u0438\u043B\u043E
        \u0442\u043E\u043B\u044C\u043A\u043E \u043D\u0430 \u0442\u0435\u0431\u044F.
        \u041D\u0430\u0447\u043D\u0438 \u043F\u043E\u043A\u0430 \u0432\u044B\u043F\u043E\u043B\u043D\u044F\u0442\u044C
        \u0441\u0432\u043E\u044E \u0447\u0430\u0441\u0442\u044C \u0441\u0434\u0435\u043B\u043A\u0438
        \u0438 \u044F \u0434\u0430\u043C \u043E \u0441\u0435\u0431\u0435 \u0437\u043D\u0430\u0442\u044C,
        \u043A\u043E\u0433\u0434\u0430 \u0431\u0443\u0434\u0443 \u0433\u043E\u0442\u043E\u0432\u0430."
      language: 1
    - text: Not yet. The balance is too disrupted, and I only had enough power for
        you. Start holding up your end of the deal, and I'll let you know when I'm
        ready.
      language: 2
    delay: 0.04
    isLeft: 0
  - speakerName: "\u0421\u043C\u0435\u0440\u0442\u044C"
    speakerNames:
    - text: "\u0421\u043C\u0435\u0440\u0442\u044C"
      language: 1
    - text: Death
      language: 2
    speakerIcon: {fileID: 21300000, guid: 1c6622693046ea845bc080110caecb67, type: 3}
    dialogueText: "\u041E\u0441\u043C\u043E\u0442\u0440\u0438\u0441\u044C \u043F\u043E\u043A\u0430,
      \u0440\u0430\u0437\u043E\u043C\u043D\u0438 \u043D\u043E\u0433\u0438, \u0440\u0443\u043A\u0438.
      \u0410 \u043A\u0430\u043A \u0431\u0443\u0434\u0435\u0448\u044C \u0433\u043E\u0442\u043E\u0432,
      \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u0439 \u043A \u0440\u0430\u0431\u043E\u0442\u0435."
    dialogueTexts:
    - text: "\u041E\u0441\u043C\u043E\u0442\u0440\u0438\u0441\u044C \u043F\u043E\u043A\u0430,
        \u0440\u0430\u0437\u043E\u043C\u043D\u0438 \u043D\u043E\u0433\u0438, \u0440\u0443\u043A\u0438.
        \u0410 \u043A\u0430\u043A \u0431\u0443\u0434\u0435\u0448\u044C \u0433\u043E\u0442\u043E\u0432,
        \u043F\u0440\u0438\u0441\u0442\u0443\u043F\u0430\u0439 \u043A \u0440\u0430\u0431\u043E\u0442\u0435."
      language: 1
    - text: Look around for now, stretch your legs, your arms. And when you're ready,
        get to work.
      language: 2
    delay: 0.04
    isLeft: 0
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 0fcb37bef2f0d76468565a50dfda6682, type: 3}
    dialogueText: "\u0425\u043E\u0440\u043E\u0448\u043E, \u0431\u0443\u0434\u0443
      \u0436\u0434\u0430\u0442\u044C."
    dialogueTexts:
    - text: "\u0425\u043E\u0440\u043E\u0448\u043E, \u0431\u0443\u0434\u0443 \u0436\u0434\u0430\u0442\u044C."
      language: 1
    - text: Alright, I'll be waiting.
      language: 2
    delay: 0.04
    isLeft: 1
  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: cd72f33c11310624eaf0322015292e31, type: 3}
    dialogueText: "\u0414\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0438."
    dialogueTexts:
    - text: "\u0414\u043E \u0432\u0441\u0442\u0440\u0435\u0447\u0438."
      language: 1
    - text: Until we meet again.
      language: 2
    delay: 0.04
    isLeft: 1
