  - speakerName: "\u041E\u0443\u044D\u043D"
    speakerNames:
    - text: "\u041E\u0443\u044D\u043D"
      language: 1
    - text: Owen
      language: 2
    speakerIcon: {fileID: 21300000, guid: 0fcb37bef2f0d76468565a50dfda6682, type: 3}
    dialogueText: "\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439 \u043C\u0435\u043D\u044F
      \u0443\u0436\u0435."
    dialogueTexts:
    - text: "\u0412\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u0439 \u043C\u0435\u043D\u044F
        \u0443\u0436\u0435."
      language: 1
    - text: Send me back already.
      language: 2
