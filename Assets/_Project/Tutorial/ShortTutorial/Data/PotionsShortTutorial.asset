  m_Name: PotionsShortTutorial
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.ShortTutorial.Scripts.ShortGameTutorialConfig
  shortGameTutorialInfos:
  - tutorialSprite: {fileID: -3850708125363898048, guid: 105d7a5999f7ecc45840501b5704266e, type: 3}
    tutorialText: "\u0412\u044B \u043A\u0443\u043F\u0438\u043B\u0438 \u0437\u0435\u043B\u044C\u0435!
      \u0427\u0442\u043E\u0431\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u0435\u0433\u043E, \u0437\u0430\u0436\u043C\u0438\u0442\u0435 \u043A\u043B\u0430\u0432\u0438\u0448\u0443
      C. \u0412 \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u043C \u043A\u043E\u043B\u0435\u0441\u0435
      \u0432\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0449\u0435\u0435
      \u0432\u0430\u0441 \u0437\u0435\u043B\u044C\u0435 \u043D\u0430\u0436\u0430\u0442\u0438\u0435\u043C
      \u043F\u043E \u043D\u0435\u043C\u0443 \u041B\u041A\u041C."
    tutorialTexts:
    - text: "\u0412\u044B \u043A\u0443\u043F\u0438\u043B\u0438 \u0437\u0435\u043B\u044C\u0435!
        \u0427\u0442\u043E\u0431\u044B \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
        \u0435\u0433\u043E, \u0437\u0430\u0436\u043C\u0438\u0442\u0435 \u043A\u043B\u0430\u0432\u0438\u0448\u0443
        C. \u0412 \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u043C \u043A\u043E\u043B\u0435\u0441\u0435
        \u0432\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0449\u0435\u0435
        \u0432\u0430\u0441 \u0437\u0435\u043B\u044C\u0435 \u043D\u0430\u0436\u0430\u0442\u0438\u0435\u043C
        \u043F\u043E \u043D\u0435\u043C\u0443 \u041B\u041A\u041C."
      language: 1
    - text: You have purchased a potion! To use it, hold down the C key. In the open
        wheel, select the potion you want by clicking on it with the left mouse button.
      language: 2
