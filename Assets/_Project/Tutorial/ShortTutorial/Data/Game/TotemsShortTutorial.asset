  m_Script: {fileID: 11500000, guid: b284ae0e8b16422c832ad614362878df, type: 3}
  m_Name: TotemsShortTutorial
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.ShortTutorial.Scripts.ShortGameTutorialConfig
  shortGameTutorialInfos:
  - tutorialSprite: {fileID: 4857784827895413297, guid: dabc27a319ebda4409c2145809559d63, type: 3}
    tutorialText: "\u042D\u0442\u043E\u0442 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
      \u0442\u043E\u0442\u0435\u043C - \u0432\u0430\u0448\u0430 \u0446\u0435\u043B\u044C
      \u0432 \u044D\u0442\u043E\u0439 \u0434\u0435\u0440\u0435\u0432\u043D\u0435.
      \u041D\u0430\u0434 \u043D\u0438\u043C \u0432\u0438\u0441\u0438\u0442 \u0444\u0438\u043E\u043B\u0435\u0442\u043E\u0432\u0430\u044F
      \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F.
      \u042D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442, \u0447\u0442\u043E
      \u043E\u043D \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
      \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D \u0441\u0435\u0439\u0447\u0430\u0441."
    tutorialTexts:
    - text: "\u042D\u0442\u043E\u0442 \u0431\u043E\u043B\u044C\u0448\u043E\u0439
        \u0442\u043E\u0442\u0435\u043C - \u0432\u0430\u0448\u0430 \u0446\u0435\u043B\u044C
        \u0432 \u044D\u0442\u043E\u0439 \u0434\u0435\u0440\u0435\u0432\u043D\u0435.
        \u041D\u0430\u0434 \u043D\u0438\u043C \u0432\u0438\u0441\u0438\u0442 \u0444\u0438\u043E\u043B\u0435\u0442\u043E\u0432\u0430\u044F
        \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F.
        \u042D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442, \u0447\u0442\u043E
        \u043E\u043D \u043D\u0435 \u043C\u043E\u0436\u0435\u0442 \u0431\u044B\u0442\u044C
        \u0440\u0430\u0437\u0440\u0443\u0448\u0435\u043D \u0441\u0435\u0439\u0447\u0430\u0441."
      language: 1
    - text: This large totem is your target in this village. There is a purple health
        bar above it. This means that it cannot be destroyed right now.
      language: 2
  - tutorialSprite: {fileID: 8959432798136660256, guid: 5849e00525865634e83b3683643c8f28, type: 3}
    tutorialText: "\u041F\u043E\u043B\u043E\u0441\u043A\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
      \u043A\u0440\u0430\u0441\u043D\u043E\u0439, \u0435\u0441\u043B\u0438 \u0432\u044B
      \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u043B\u0438 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435
      \u0442\u043E\u0442\u0435\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u043F\u0438\u0442\u0430\u044E\u0442 \u0437\u0430\u0449\u0438\u0442\u0443 \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E
      \u0442\u043E\u0442\u0435\u043C\u0430. "
    tutorialTexts:
    - text: "\u041F\u043E\u043B\u043E\u0441\u043A\u0430 \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F
        \u043A\u0440\u0430\u0441\u043D\u043E\u0439, \u0435\u0441\u043B\u0438 \u0432\u044B
        \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u043B\u0438 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435
        \u0442\u043E\u0442\u0435\u043C\u044B, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
        \u043F\u0438\u0442\u0430\u044E\u0442 \u0437\u0430\u0449\u0438\u0442\u0443
        \u0431\u043E\u043B\u044C\u0448\u043E\u0433\u043E \u0442\u043E\u0442\u0435\u043C\u0430. "
      language: 1
    - text: The bar turns red if you destroy the small totems that power the big
        totem's protection.
      language: 2
  - tutorialSprite: {fileID: 7756741228319395535, guid: f972aef3b9629f04ca7dccb2a11aeed8, type: 3}
    tutorialText: "\u042D\u0442\u043E \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
      \u0442\u043E\u0442\u0435\u043C. \u0415\u0433\u043E \u043F\u043E\u043B\u043E\u0441\u043A\u0430
      \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u0444\u0438\u043E\u043B\u0435\u0442\u043E\u0432\u0430\u044F,
      \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043A\u0443\u043B\u044C\u0442\u0438\u0441\u0442,
      \u0437\u0430\u0449\u0438\u0449\u0430\u044E\u0449\u0438\u0439 \u0442\u043E\u0442\u0435\u043C,
      \u0432\u0441\u0451 \u0435\u0449\u0451 \u0436\u0438\u0432. \u041E\u043D \u0434\u043E\u043B\u0436\u0435\u043D
      \u0431\u044B\u0442\u044C \u0440\u044F\u0434\u043E\u043C \u0441 \u0442\u043E\u0442\u0435\u043C\u043E\u043C.
      \u0414\u0430\u0436\u0435 \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0431\u043B\u0438\u0437\u043A\u043E., "
    tutorialTexts:
    - text: "\u042D\u0442\u043E \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439
        \u0442\u043E\u0442\u0435\u043C. \u0415\u0433\u043E \u043F\u043E\u043B\u043E\u0441\u043A\u0430
        \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u0444\u0438\u043E\u043B\u0435\u0442\u043E\u0432\u0430\u044F,
        \u043F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u043A\u0443\u043B\u044C\u0442\u0438\u0441\u0442,
        \u0437\u0430\u0449\u0438\u0449\u0430\u044E\u0449\u0438\u0439 \u0442\u043E\u0442\u0435\u043C,
        \u0432\u0441\u0451 \u0435\u0449\u0451 \u0436\u0438\u0432. \u041E\u043D \u0434\u043E\u043B\u0436\u0435\u043D
        \u0431\u044B\u0442\u044C \u0440\u044F\u0434\u043E\u043C \u0441 \u0442\u043E\u0442\u0435\u043C\u043E\u043C.
        \u0414\u0430\u0436\u0435 \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0431\u043B\u0438\u0437\u043A\u043E., "
      language: 1
    - text: This is a small totem. Its health bar is purple because the cultist protecting
        the totem is still alive. He must be close to the totem. Even too close.,
      language: 2
  - tutorialSprite: {fileID: -6981502392048913090, guid: 66ed1fe959c3aba4f81d1239b67508de, type: 3}
    tutorialText: "\u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u0431\u0435\u0434\u044B
      \u043D\u0430\u0434 \u043A\u0443\u043B\u044C\u0442\u0438\u0441\u0442\u043E\u043C,
      \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
      \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0433\u043E \u0442\u043E\u0442\u0435\u043C\u0430
      \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u043A\u0440\u0430\u0441\u043D\u043E\u0439
      \u0438 \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0435\u0433\u043E
      \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u044C. "
    tutorialTexts:
    - text: "\u041F\u043E\u0441\u043B\u0435 \u043F\u043E\u0431\u0435\u0434\u044B
        \u043D\u0430\u0434 \u043A\u0443\u043B\u044C\u0442\u0438\u0441\u0442\u043E\u043C,
        \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
        \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u043E\u0433\u043E \u0442\u043E\u0442\u0435\u043C\u0430
        \u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u0441\u044F \u043A\u0440\u0430\u0441\u043D\u043E\u0439
        \u0438 \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0435\u0433\u043E
        \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u044C. "
      language: 1
    - text: After defeating the cultist, the small totem's health bar turns red,
        allowing you to destroy it.
      language: 2
  - tutorialSprite: {fileID: 4857784827895413297, guid: dabc27a319ebda4409c2145809559d63, type: 3}
    tutorialText: "\u0421\u043E\u0432\u0435\u0442: \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435
      \u043D\u0430\u043D\u0435\u0441\u0442\u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u0443
      \u043F\u043E\u0434 \u0437\u0430\u0449\u0438\u0442\u043E\u0439 \u0443\u0440\u043E\u043D.
      \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442 \u0432\u0430\u043C
      \u0441\u0440\u0430\u0437\u0443 \u043D\u0430\u043D\u0435\u0441\u0442\u0438 \u0431\u043E\u043B\u044C\u0448\u0443\u044E
      \u0447\u0430\u0441\u0442\u044C \u0443\u0440\u043E\u043D\u0430 \u0438 \u043A\u043E\u0433\u0434\u0430
      \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
      \u0441\u0442\u0430\u043D\u0435\u0442 \u043A\u0440\u0430\u0441\u043D\u043E\u0439,
      \u0432\u0430\u043C \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F \u043D\u0430\u043D\u0435\u0441\u0442\u0438
      \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439 \u0443\u0440\u043E\u043D."
    tutorialTexts:
    - text: "\u0421\u043E\u0432\u0435\u0442: \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435
        \u043D\u0430\u043D\u0435\u0441\u0442\u0438 \u043E\u0431\u044A\u0435\u043A\u0442\u0443
        \u043F\u043E\u0434 \u0437\u0430\u0449\u0438\u0442\u043E\u0439 \u0443\u0440\u043E\u043D.
        \u042D\u0442\u043E \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442 \u0432\u0430\u043C
        \u0441\u0440\u0430\u0437\u0443 \u043D\u0430\u043D\u0435\u0441\u0442\u0438
        \u0431\u043E\u043B\u044C\u0448\u0443\u044E \u0447\u0430\u0441\u0442\u044C
        \u0443\u0440\u043E\u043D\u0430 \u0438 \u043A\u043E\u0433\u0434\u0430 \u043F\u043E\u043B\u043E\u0441\u043A\u0430
        \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F \u0441\u0442\u0430\u043D\u0435\u0442
        \u043A\u0440\u0430\u0441\u043D\u043E\u0439, \u0432\u0430\u043C \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F
        \u043D\u0430\u043D\u0435\u0441\u0442\u0438 \u0440\u0435\u0448\u0430\u044E\u0449\u0438\u0439
        \u0443\u0440\u043E\u043D."
      language: 1
    - text: 'Tip: You can deal damage to an object that is protected. This will allow
        you to deal most of the damage immediately, and when the health bar turns
        red, you will only need to deal the final damage.'
      language: 2
