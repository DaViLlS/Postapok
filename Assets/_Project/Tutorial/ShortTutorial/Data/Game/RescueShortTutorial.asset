  m_Script: {fileID: 11500000, guid: b284ae0e8b16422c832ad614362878df, type: 3}
  m_Name: RescueShortTutorial
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.ShortTutorial.Scripts.ShortGameTutorialConfig
  shortGameTutorialInfos:
  - tutorialSprite: {fileID: 6185249978412960480, guid: d636fb50c997376469314e7b27a50db2, type: 3}
    tutorialText: "\u0416\u0438\u0442\u0435\u043B\u0438, \u043D\u0430\u0434 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
      \u0432\u0438\u0441\u044F\u0442 \u043F\u043E\u043B\u043E\u0441\u043A\u0438 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F
      - \u043D\u0435 \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u044B. \u041D\u0430
      \u0443\u0440\u043E\u0432\u043D\u0435 \u043F\u043E \u0441\u043F\u0430\u0441\u0435\u043D\u0438\u044E
      \u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u0432\u0430\u043C \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
      \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u044D\u0442\u0438\u0445 \u0431\u0435\u0434\u043E\u043B\u0430\u0433
      \u043A \u0432\u044B\u0445\u043E\u0434\u0443 \u0438\u0437 \u0434\u0435\u0440\u0435\u0432\u043D\u0438."
    tutorialTexts:
    - text: "\u0416\u0438\u0442\u0435\u043B\u0438, \u043D\u0430\u0434 \u043A\u043E\u0442\u043E\u0440\u044B\u043C\u0438
        \u0432\u0438\u0441\u044F\u0442 \u043F\u043E\u043B\u043E\u0441\u043A\u0438
        \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F - \u043D\u0435 \u043E\u0434\u0435\u0440\u0436\u0438\u043C\u044B.
        \u041D\u0430 \u0443\u0440\u043E\u0432\u043D\u0435 \u043F\u043E \u0441\u043F\u0430\u0441\u0435\u043D\u0438\u044E
        \u0436\u0438\u0442\u0435\u043B\u0435\u0439 \u0432\u0430\u043C \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
        \u0432\u044B\u0432\u0435\u0441\u0442\u0438 \u044D\u0442\u0438\u0445 \u0431\u0435\u0434\u043E\u043B\u0430\u0433
        \u043A \u0432\u044B\u0445\u043E\u0434\u0443 \u0438\u0437 \u0434\u0435\u0440\u0435\u0432\u043D\u0438."
      language: 1
    - text: The villagers with health bars are not possessed. In the villagers' rescue
        level, you need to lead these poor souls out of the village.
      language: 2
  - tutorialSprite: {fileID: 6185249978412960480, guid: d636fb50c997376469314e7b27a50db2, type: 3}
    tutorialText: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043D\u0435\u0436\u0438\u0442\u044C
      \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u041F\u041A\u041C \u043F\u043E
      \u0436\u0438\u0442\u0435\u043B\u044E, \u0447\u0442\u043E\u0431\u044B \u043D\u0435\u0436\u0438\u0442\u044C
      \u043D\u0430\u0447\u0430\u043B\u0430 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u0442\u044C
      \u0435\u0433\u043E. \u0415\u0441\u043B\u0438 \u043D\u0435\u0436\u0438\u0442\u044C
      \u0434\u0430\u043B\u0435\u043A\u043E, \u0442\u043E \u0436\u0438\u0442\u0435\u043B\u044C
      \u043D\u0438\u043A\u0443\u0434\u0430 \u0438\u0434\u0442\u0438 \u043D\u0435
      \u0431\u0443\u0434\u0435\u0442. "
    tutorialTexts:
    - text: "\u0412\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u043D\u0435\u0436\u0438\u0442\u044C
        \u0438 \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u041F\u041A\u041C \u043F\u043E
        \u0436\u0438\u0442\u0435\u043B\u044E, \u0447\u0442\u043E\u0431\u044B \u043D\u0435\u0436\u0438\u0442\u044C
        \u043D\u0430\u0447\u0430\u043B\u0430 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u0442\u044C
        \u0435\u0433\u043E. \u0415\u0441\u043B\u0438 \u043D\u0435\u0436\u0438\u0442\u044C
        \u0434\u0430\u043B\u0435\u043A\u043E, \u0442\u043E \u0436\u0438\u0442\u0435\u043B\u044C
        \u043D\u0438\u043A\u0443\u0434\u0430 \u0438\u0434\u0442\u0438 \u043D\u0435
        \u0431\u0443\u0434\u0435\u0442. "
      language: 1
    - text: Select the undead and right-click on the villager to make the undead
        follow them. If the undead is too far away, the villager will not move.
      language: 2
  - tutorialSprite: {fileID: 6185249978412960480, guid: d636fb50c997376469314e7b27a50db2, type: 3}
    tutorialText: "\u0423 \u0436\u0438\u0442\u0435\u043B\u044F \u0435\u0441\u0442\u044C
      \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0442\u0440\u0435\u0432\u043E\u0433\u0438.
      \u0415\u0433\u043E \u043D\u0435 \u0432\u0438\u0434\u043D\u043E, \u043D\u043E
      \u043E\u043A\u043E\u043B\u043E \u043D\u0435\u0433\u043E \u043A\u0430\u043A\u043E\u0435-\u0442\u043E
      \u0432\u0440\u0435\u043C\u044F \u0431\u0443\u0434\u0435\u0442 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
      \u0432\u0440\u0430\u0433, \u0442\u043E \u0436\u0438\u0442\u0435\u043B\u044C
      \u0438\u0441\u043F\u0443\u0433\u0430\u0435\u0442\u0441\u044F \u0438 \u043F\u043E\u0431\u0435\u0436\u0438\u0442
      \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0435 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0435
      \u043C\u0435\u0441\u0442\u043E. \u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E,
      \u043A\u0430\u043A \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0442\u0440\u0435\u0432\u043E\u0433\u0438
      \u0443\u043F\u0430\u0434\u0451\u0442, \u043E\u043D \u0441\u043C\u043E\u0436\u0435\u0442
      \u0441\u043D\u043E\u0432\u0430 \u043F\u0440\u043E\u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
      \u043A \u0432\u044B\u0445\u043E\u0434\u0443."
    tutorialTexts:
    - text: "\u0423 \u0436\u0438\u0442\u0435\u043B\u044F \u0435\u0441\u0442\u044C
        \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0442\u0440\u0435\u0432\u043E\u0433\u0438.
        \u0415\u0433\u043E \u043D\u0435 \u0432\u0438\u0434\u043D\u043E. \u0415\u0441\u043B\u0438
        \u043E\u043A\u043E\u043B\u043E \u043D\u0435\u0433\u043E \u043A\u0430\u043A\u043E\u0435-\u0442\u043E
        \u0432\u0440\u0435\u043C\u044F \u0431\u0443\u0434\u0435\u0442 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
        \u0432\u0440\u0430\u0433, \u0442\u043E \u0436\u0438\u0442\u0435\u043B\u044C
        \u0438\u0441\u043F\u0443\u0433\u0430\u0435\u0442\u0441\u044F \u0438 \u043F\u043E\u0431\u0435\u0436\u0438\u0442
        \u0432 \u0431\u043B\u0438\u0436\u0430\u0439\u0448\u0435\u0435 \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0435
        \u043C\u0435\u0441\u0442\u043E. \u041F\u043E\u0441\u043B\u0435 \u0442\u043E\u0433\u043E,
        \u043A\u0430\u043A \u0443\u0440\u043E\u0432\u0435\u043D\u044C \u0442\u0440\u0435\u0432\u043E\u0433\u0438
        \u0443\u043F\u0430\u0434\u0451\u0442, \u043E\u043D \u0441\u043C\u043E\u0436\u0435\u0442
        \u0441\u043D\u043E\u0432\u0430 \u043F\u0440\u043E\u0434\u0432\u0438\u0433\u0430\u0442\u044C\u0441\u044F
        \u043A \u0432\u044B\u0445\u043E\u0434\u0443."
      language: 1
    - text: The resident has an alarm level. It is not visible. If an enemy is near
        the resident for a while, the resident will become frightened and run to
        the nearest safe place. Once the alarm level drops, the resident will be
        able to move towards the exit again.
      language: 2
  - tutorialSprite: {fileID: 6185249978412960480, guid: d636fb50c997376469314e7b27a50db2, type: 3}
    tutorialText: "\u0416\u0438\u0442\u0435\u043B\u044C \u043C\u043E\u0436\u0435\u0442
      \u043F\u043E\u0433\u0438\u0431\u043D\u0443\u0442\u044C, \u043D\u043E \u043D\u0435
      \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0439\u0442\u0435. \u0423\u0440\u043E\u0432\u0435\u043D\u044C
      \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u043E\u0439\u0442\u0438, \u043F\u043E\u0442\u0435\u0440\u044F\u0432
      \u043F\u0430\u0440\u0443 \u0436\u0438\u0442\u0435\u043B\u0435\u0439, \u043D\u043E
      \u0437\u0430 \u044D\u0442\u043E \u043E\u0442\u043D\u0438\u043C\u0435\u0442\u0441\u044F
      \u0447\u0430\u0441\u0442\u044C \u043D\u0430\u0433\u0440\u0430\u0434\u044B.
      \u0412\u044B \u0432\u0441\u0435\u0433\u0434\u0430 \u043C\u043E\u0436\u0435\u0442\u0435
      \u043F\u0435\u0440\u0435\u043F\u0440\u043E\u0439\u0442\u0438 \u0443\u0440\u043E\u0432\u0435\u043D\u044C,
      \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043F\u044B\u0442\u0430\u0442\u044C\u0441\u044F
      \u0441\u043F\u0430\u0441\u0442\u0438 \u0438\u0445 \u0432\u0441\u0435\u0445."
    tutorialTexts:
    - text: "\u0416\u0438\u0442\u0435\u043B\u044C \u043C\u043E\u0436\u0435\u0442
        \u043F\u043E\u0433\u0438\u0431\u043D\u0443\u0442\u044C, \u043D\u043E \u043D\u0435
        \u043F\u0435\u0440\u0435\u0436\u0438\u0432\u0430\u0439\u0442\u0435. \u0423\u0440\u043E\u0432\u0435\u043D\u044C
        \u043C\u043E\u0436\u043D\u043E \u043F\u0440\u043E\u0439\u0442\u0438, \u043F\u043E\u0442\u0435\u0440\u044F\u0432
        \u043F\u0430\u0440\u0443 \u0436\u0438\u0442\u0435\u043B\u0435\u0439, \u043D\u043E
        \u0437\u0430 \u044D\u0442\u043E \u043E\u0442\u043D\u0438\u043C\u0435\u0442\u0441\u044F
        \u0447\u0430\u0441\u0442\u044C \u043D\u0430\u0433\u0440\u0430\u0434\u044B.
        \u0412\u044B \u0432\u0441\u0435\u0433\u0434\u0430 \u043C\u043E\u0436\u0435\u0442\u0435
        \u043F\u0435\u0440\u0435\u043F\u0440\u043E\u0439\u0442\u0438 \u0443\u0440\u043E\u0432\u0435\u043D\u044C,
        \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043F\u044B\u0442\u0430\u0442\u044C\u0441\u044F
        \u0441\u043F\u0430\u0441\u0442\u0438 \u0438\u0445 \u0432\u0441\u0435\u0445."
      language: 1
    - text: A resident may die, but don't worry. You can complete the level by losing
        a couple of residents, but this will reduce your reward. You can always replay
        the level to try to save them all.
      language: 2
