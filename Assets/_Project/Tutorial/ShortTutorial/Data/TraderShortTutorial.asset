  m_Script: {fileID: 11500000, guid: b284ae0e8b16422c832ad614362878df, type: 3}
  m_Name: TraderShortTutorial
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.ShortTutorial.Scripts.ShortGameTutorialConfig
  shortGameTutorialInfos:
  - tutorialSprite: {fileID: -4877766353376459641, guid: 02502b82ff07a8e42a2229c1ba4dde9a, type: 3}
    tutorialText: "\u042D\u0442\u043E - \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446.
      \u0423 \u043D\u0435\u0433\u043E \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435
      \u043A\u0443\u043F\u0438\u0442\u044C \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C.
      \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0437\u0430\u043F\u0438\u0441\u0438
      \u0434\u043B\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u043D\u0430\u0432\u044B\u043A\u0430
      \u0438\u043B\u0438 \u0437\u0435\u043B\u044C\u044F."
    tutorialTexts:
    - text: "\u042D\u0442\u043E - \u0442\u043E\u0440\u0433\u043E\u0432\u0435\u0446.
        \u0423 \u043D\u0435\u0433\u043E \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435
        \u043A\u0443\u043F\u0438\u0442\u044C \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C.
        \u041D\u0430\u043F\u0440\u0438\u043C\u0435\u0440, \u0437\u0430\u043F\u0438\u0441\u0438
        \u0434\u043B\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u043D\u0430\u0432\u044B\u043A\u0430
        \u0438\u043B\u0438 \u0437\u0435\u043B\u044C\u044F."
      language: 1
    - text: This is a merchant. You can buy something from him. For example, records
        for unlocking a skill or a potion.
      language: 2
  - tutorialSprite: {fileID: -4877766353376459641, guid: 02502b82ff07a8e42a2229c1ba4dde9a, type: 3}
    tutorialText: "\u041D\u043E \u043F\u043E\u043A\u0443\u043F\u0430\u0439\u0442\u0435
      \u0437\u0435\u043B\u044C\u044F \u0441 \u0443\u043C\u043E\u043C. \u041F\u043E\u0441\u043B\u0435
      \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u043E\u0432\u043D\u044F
      \u043E\u043D\u0438 \u043F\u0440\u043E\u043F\u0430\u0434\u0430\u044E\u0442,
      \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D\u0438 \u043D\u0435 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B
      \u0438 \u0438\u0445 \u0441\u0440\u043E\u043A \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438
      \u043E\u0447\u0435\u043D\u044C \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0439."
    tutorialTexts:
    - text: "\u041D\u043E \u043F\u043E\u043A\u0443\u043F\u0430\u0439\u0442\u0435
        \u0437\u0435\u043B\u044C\u044F \u0441 \u0443\u043C\u043E\u043C. \u041F\u043E\u0441\u043B\u0435
        \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u0438\u044F \u0443\u0440\u043E\u0432\u043D\u044F
        \u043E\u043D\u0438 \u043F\u0440\u043E\u043F\u0430\u0434\u0430\u044E\u0442,
        \u0442\u0430\u043A \u043A\u0430\u043A \u043E\u043D\u0438 \u043D\u0435 \u0438\u0434\u0435\u0430\u043B\u044C\u043D\u044B
        \u0438 \u0438\u0445 \u0441\u0440\u043E\u043A \u0433\u043E\u0434\u043D\u043E\u0441\u0442\u0438
        \u043E\u0447\u0435\u043D\u044C \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0439."
      language: 1
    - text: But buy potions wisely. After completing a level, they disappear because
        they are not perfect and have a very short shelf life.
      language: 2
