  m_text: "\u041D\u0443 \u043A\u043E\u0440\u043E\u0447\u0435 \u0447\u0442\u043E\u0431\u044B
    \u043E\u0442\u044A\u0435\u0431\u0430\u0442\u044C \u0442\u043E\u0442\u0435\u043C
    \u0431\u043E\u043B\u044C\u0448\u043E\u0439, \u043D\u0430\u0434\u043E \u0441\u043D\u0430\u0447\u0430\u043B\u0430
    \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435 \u0440\u0430\u0437\u044A\u0435\u0431\u0430\u0442\u044C.
    \u0410 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435 \u0440\u0430\u0437\u044A\u0435\u0431\u044B\u0432\u0430\u044E\u0442\u0441\u044F
    \u043F\u043E\u0441\u043B\u0435 \u043E\u043F\u0438\u0437\u0434\u044E\u043B\u0438\u0432\u0430\u043D\u0438\u044F
    \u043A\u0443\u043B\u044C\u0442\u0438\u0441\u0442\u0430, \u0441\u0442\u043E\u044F\u0449\u0435\u0433\u043E
