  title: "\u0418\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u043D\u0430\u0432\u044B\u043A\u043E\u0432"
  titles:
  - text: "\u0418\u0437\u0443\u0447\u0435\u043D\u0438\u0435 \u043D\u0430\u0432\u044B\u043A\u043E\u0432"
    language: 1
  - text: Learning skills
    language: 2
  description: "\u0417\u0434\u0435\u0441\u044C \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u044E\u0442\u0441\u044F
    \u043D\u0430\u0432\u044B\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
    \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0438\u0437\u0443\u0447\u0438\u0442\u044C
    \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0441\u0435\u0431\u0435
    \u0434\u043B\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F."
  descriptions:
  - text: "\u0417\u0434\u0435\u0441\u044C \u043E\u0442\u043E\u0431\u0440\u0430\u0436\u0430\u044E\u0442\u0441\u044F
      \u043D\u0430\u0432\u044B\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
      \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0438\u0437\u0443\u0447\u0438\u0442\u044C
      \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C \u0441\u0435\u0431\u0435
      \u0434\u043B\u044F \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043D\u0438\u044F."
    language: 1
  - text: This displays the skills that you can learn and use.
    language: 2
