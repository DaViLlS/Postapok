  title: "\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u0443\u0440\u043E\u0432\u043D\u044F"
  titles:
  - text: "\u0418\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
      \u0443\u0440\u043E\u0432\u043D\u044F"
    language: 1
  - text: Level research
    language: 2
  description: "\u0427\u0442\u043E\u0431\u044B \u043E\u0442\u043A\u0440\u044B\u0442\u044C
    \u043D\u043E\u0432\u044B\u0439 \u0443\u0440\u043E\u0432\u0435\u043D\u044C, \u043D\u0443\u0436\u043D\u043E
    \u043D\u0430\u0447\u0430\u0442\u044C \u0435\u0433\u043E \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
    \u0438 \u0434\u043E\u0436\u0434\u0430\u0442\u044C\u0441\u044F \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u044F
    \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0433\u043E
    \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
  descriptions:
  - text: "\u0427\u0442\u043E\u0431\u044B \u043E\u0442\u043A\u0440\u044B\u0442\u044C
      \u043D\u043E\u0432\u044B\u0439 \u0443\u0440\u043E\u0432\u0435\u043D\u044C,
      \u043D\u0443\u0436\u043D\u043E \u043D\u0430\u0447\u0430\u0442\u044C \u0435\u0433\u043E
      \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435 \u0438
      \u0434\u043E\u0436\u0434\u0430\u0442\u044C\u0441\u044F \u043E\u043A\u043E\u043D\u0447\u0430\u043D\u0438\u044F
      \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E\u0433\u043E
      \u043A\u043E\u043B\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u0432\u0440\u0435\u043C\u0435\u043D\u0438."
    language: 1
  - text: To open a new level, you need to start exploring it and wait for a certain
      amount of time to pass.
    language: 2
