  m_Name: MainMenuExplanation
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u0418\u0433\u0440\u043E\u0432\u043E\u0435 \u043C\u0435\u043D\u044E"
  titles:
  - text: "\u0418\u0433\u0440\u043E\u0432\u043E\u0435 \u043C\u0435\u043D\u044E"
    language: 1
  - text: Game menu
    language: 2
  description: "\u0417\u0434\u0435\u0441\u044C \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435
    \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u043B\u044E\u0431\u043E\u0439 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0439
    \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0449\u0438\u0439
    \u0432\u0430\u0441 \u0443\u0440\u043E\u0432\u0435\u043D\u044C, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C\u0441\u044F
    \u043A \u043D\u0435\u043C\u0443 \u0434\u043E\u043B\u0436\u043D\u044B\u043C \u043E\u0431\u0440\u0430\u0437\u043E\u043C."
  descriptions:
  - text: "\u0417\u0434\u0435\u0441\u044C \u0432\u044B \u043C\u043E\u0436\u0435\u0442\u0435
      \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u043B\u044E\u0431\u043E\u0439 \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u044B\u0439
      \u0438 \u0438\u043D\u0442\u0435\u0440\u0435\u0441\u0443\u044E\u0449\u0438\u0439
      \u0432\u0430\u0441 \u0443\u0440\u043E\u0432\u0435\u043D\u044C, \u0430 \u0442\u0430\u043A\u0436\u0435
      \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C\u0441\u044F
      \u043A \u043D\u0435\u043C\u0443 \u0434\u043E\u043B\u0436\u043D\u044B\u043C
      \u043E\u0431\u0440\u0430\u0437\u043E\u043C."
    language: 1
  - text: Here, you can choose any level that interests you and prepare for it properly.
    language: 2
