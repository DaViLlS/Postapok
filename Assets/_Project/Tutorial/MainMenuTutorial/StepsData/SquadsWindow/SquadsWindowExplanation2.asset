  title: "\u041E\u043A\u043D\u043E \u043E\u0442\u0440\u044F\u0434\u043E\u0432"
  titles:
  - text: "\u041E\u043A\u043D\u043E \u043E\u0442\u0440\u044F\u0434\u043E\u0432"
    language: 1
  - text: Squad Window
    language: 2
  description: "\u041E\u0442\u0440\u044F\u0434\u044B \u0432 \u0438\u0433\u0440\u0435
    \u0431\u0443\u0434\u0443\u0442 \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F
    \u0442\u0430\u043A, \u043A\u0430\u043A \u0432\u044B \u0443\u043A\u0430\u0437\u0430\u043B\u0438
    \u044D\u0442\u043E \u0432 \u0441\u0432\u043E\u0451\u043C \u0448\u0430\u0431\u043B\u043E\u043D\u0435."
  descriptions:
  - text: "\u041E\u0442\u0440\u044F\u0434\u044B \u0432 \u0438\u0433\u0440\u0435 \u0431\u0443\u0434\u0443\u0442
      \u0444\u043E\u0440\u043C\u0438\u0440\u043E\u0432\u0430\u0442\u044C\u0441\u044F
      \u0442\u0430\u043A, \u043A\u0430\u043A \u0432\u044B \u0443\u043A\u0430\u0437\u0430\u043B\u0438
      \u044D\u0442\u043E \u0432 \u0441\u0432\u043E\u0451\u043C \u0448\u0430\u0431\u043B\u043E\u043D\u0435."
    language: 1
  - text: The squads in the game will be formed as you specified in your template.
    language: 2
