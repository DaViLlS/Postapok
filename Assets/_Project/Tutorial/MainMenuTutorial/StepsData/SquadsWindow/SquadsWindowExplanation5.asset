  m_Script: {fileID: 11500000, guid: 0e5a5816d4b94082a5d68d5c7bf86e71, type: 3}
  m_Name: SquadsWindowExplanation5
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u041E\u043A\u043D\u043E \u043E\u0442\u0440\u044F\u0434\u043E\u0432"
  titles:
  - text: "\u041E\u043A\u043D\u043E \u043E\u0442\u0440\u044F\u0434\u043E\u0432"
    language: 1
  - text: Squad Window
    language: 2
  description: "\u0412 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u043C
    \u0432\u044B \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u0442\u044C
    \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E
    \u0432 \u043E\u0442\u0440\u044F\u0434\u0435, \u0430 \u0442\u0430\u043A\u0436\u0435
    \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
    \u0432\u0442\u043E\u0440\u043E\u0439 \u0438 \u0434\u0430\u0436\u0435 \u0442\u0440\u0435\u0442\u0438\u0439
    \u0448\u0430\u0431\u043B\u043E\u043D\u044B!"
  descriptions:
  - text: "\u0412 \u0434\u0430\u043B\u044C\u043D\u0435\u0439\u0448\u0435\u043C \u0432\u044B
      \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u0440\u0430\u0441\u0448\u0438\u0440\u0438\u0442\u044C
      \u043C\u0430\u043A\u0441\u0438\u043C\u0430\u043B\u044C\u043D\u043E\u0435 \u043C\u0435\u0441\u0442\u043E
      \u0432 \u043E\u0442\u0440\u044F\u0434\u0435, \u0430 \u0442\u0430\u043A\u0436\u0435
      \u0441\u043C\u043E\u0436\u0435\u0442\u0435 \u0441\u0434\u0435\u043B\u0430\u0442\u044C
      \u0432\u0442\u043E\u0440\u043E\u0439 \u0438 \u0434\u0430\u0436\u0435 \u0442\u0440\u0435\u0442\u0438\u0439
      \u0448\u0430\u0431\u043B\u043E\u043D\u044B!"
    language: 1
  - text: In the future, you will be able to expand the maximum number of members
      in a squad, as well as create a second and even a third template!
    language: 2
