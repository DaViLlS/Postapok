  m_Script: {fileID: 11500000, guid: 0e5a5816d4b94082a5d68d5c7bf86e71, type: 3}
  m_Name: SoulAppearanceExplanation
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u041D\u043E\u0432\u044B\u0435 \u0434\u0443\u0448\u0438"
  titles:
  - text: "\u041D\u043E\u0432\u044B\u0435 \u0434\u0443\u0448\u0438"
    language: 1
  - text: New souls
    language: 2
  description: "\u041F\u043E\u0441\u043B\u0435 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0438\u044F
    \u0432\u0440\u0430\u0433\u043E\u0432 \u0435\u0441\u0442\u044C \u0448\u0430\u043D\u0441,
    \u0447\u0442\u043E \u0434\u0443\u0448\u0430 \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F.
    \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
    \u044D\u0442\u0438 \u0434\u0443\u0448\u0438 \u0434\u043B\u044F \u043F\u0440\u0438\u0437\u044B\u0432\u0430
    \u043D\u043E\u0432\u043E\u0439 \u043D\u0435\u0436\u0438\u0442\u0438. "
  descriptions:
  - text: "\u041F\u043E\u0441\u043B\u0435 \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0438\u044F
      \u0432\u0440\u0430\u0433\u043E\u0432 \u0435\u0441\u0442\u044C \u0448\u0430\u043D\u0441,
      \u0447\u0442\u043E \u0434\u0443\u0448\u0430 \u043E\u0441\u0442\u0430\u043D\u0435\u0442\u0441\u044F.
      \u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u0442\u044C
      \u044D\u0442\u0438 \u0434\u0443\u0448\u0438 \u0434\u043B\u044F \u043F\u0440\u0438\u0437\u044B\u0432\u0430
      \u043D\u043E\u0432\u043E\u0439 \u043D\u0435\u0436\u0438\u0442\u0438. "
    language: 1
  - text: After destroying enemies, there is a chance that a soul will remain. You
      can use these souls to summon new undead.
    language: 2
