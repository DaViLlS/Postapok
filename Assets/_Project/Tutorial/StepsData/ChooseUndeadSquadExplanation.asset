  m_Script: {fileID: 11500000, guid: 0e5a5816d4b94082a5d68d5c7bf86e71, type: 3}
  m_Name: ChooseUndeadSquadExplanation
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u0412\u044B\u0431\u043E\u0440 \u043E\u0442\u0440\u044F\u0434\u0430"
  titles:
  - text: "\u0412\u044B\u0431\u043E\u0440 \u043E\u0442\u0440\u044F\u0434\u0430"
    language: 1
  - text: Choosing a squad
    language: 2
  description: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0432\u044B\u0431\u0440\u0430\u0442\u044C
    \u043A\u0430\u043A \u043E\u0434\u0438\u043D, \u0442\u0430\u043A \u0438 \u0441\u0440\u0430\u0437\u0443
    \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043E\u0442\u0440\u044F\u0434\u043E\u0432.
    \u041D\u0430\u0436\u0430\u0442\u0438\u0435 \u041B\u041A\u041C \u043F\u043E \u043D\u0435\u0436\u0438\u0442\u0438
    \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442 \u0432\u044B\u0431\u043E\u0440\u043E\u0447\u043D\u043E
    \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C \u043D\u0443\u0436\u043D\u044B\u0435
    \u043E\u0442\u0440\u044F\u0434\u044B, \u0430 \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u043E\u0431\u043B\u0430\u0441\u0442\u0438 \u0437\u0430\u0436\u0430\u0442\u044B\u043C
    \u041B\u041A\u041C \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442 \u0432\u044B\u0431\u0440\u0430\u0442\u044C
    \u0432\u0441\u0435 \u043E\u0442\u0440\u044F\u0434\u044B, \u043D\u0430\u0445\u043E\u0434\u044F\u0449\u0438\u0435\u0441\u044F
    \u0432 \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0439 \u043E\u0431\u043B\u0430\u0441\u0442\u0438."
  descriptions:
  - text: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0432\u044B\u0431\u0440\u0430\u0442\u044C
      \u043A\u0430\u043A \u043E\u0434\u0438\u043D, \u0442\u0430\u043A \u0438 \u0441\u0440\u0430\u0437\u0443
      \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E \u043E\u0442\u0440\u044F\u0434\u043E\u0432.
      \u041D\u0430\u0436\u0430\u0442\u0438\u0435 \u041B\u041A\u041C \u043F\u043E
      \u043D\u0435\u0436\u0438\u0442\u0438 \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442
      \u0432\u044B\u0431\u043E\u0440\u043E\u0447\u043D\u043E \u0432\u044B\u0434\u0435\u043B\u0438\u0442\u044C
      \u043D\u0443\u0436\u043D\u044B\u0435 \u043E\u0442\u0440\u044F\u0434\u044B,
      \u0430 \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u0438\u0435 \u043E\u0431\u043B\u0430\u0441\u0442\u0438
      \u0437\u0430\u0436\u0430\u0442\u044B\u043C \u041B\u041A\u041C \u043F\u043E\u0437\u0432\u043E\u043B\u0438\u0442
      \u0432\u044B\u0431\u0440\u0430\u0442\u044C \u0432\u0441\u0435 \u043E\u0442\u0440\u044F\u0434\u044B,
      \u043D\u0430\u0445\u043E\u0434\u044F\u0449\u0438\u0435\u0441\u044F \u0432 \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u043D\u043E\u0439
      \u043E\u0431\u043B\u0430\u0441\u0442\u0438."
    language: 1
  - text: You can select either one or multiple units at once. LMB clicking on the
      undead will allow you to select the units you want selectively, and selecting
      an area with LMB held down will select all units in the area.
    language: 2
