  m_Script: {fileID: 11500000, guid: 0e5a5816d4b94082a5d68d5c7bf86e71, type: 3}
  m_Name: FreeCameraLookAt
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u041F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u0435 \u043A\u0430\u043C\u0435\u0440\u044B"
  titles:
  - text: "\u041F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u0435 \u043A\u0430\u043C\u0435\u0440\u044B"
    language: 1
  - text: Moving the camera
    language: 2
  description: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435
    \u043A\u043B\u0430\u0432\u0438\u0448\u0438 WASD, \u0447\u0442\u043E\u0431\u044B
    \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0430\u0442\u044C \u043A\u0430\u043C\u0435\u0440\u0443.
    \u0421\u043B\u0435\u0434\u0443\u044F \u0437\u0430 \u043C\u0430\u0440\u043A\u0435\u0440\u043E\u043C,
    \u043D\u0430\u0432\u0435\u0434\u0438\u0442\u0435\u0441\u044C \u043A\u0430\u043C\u0435\u0440\u043E\u0439
    \u043D\u0430 \u0432\u0440\u0430\u0436\u0435\u0441\u043A\u0438\u0439 \u043E\u0442\u0440\u044F\u0434."
  descriptions:
  - text: "\u0418\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439\u0442\u0435 \u043A\u043B\u0430\u0432\u0438\u0448\u0438
      WASD, \u0447\u0442\u043E\u0431\u044B \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0430\u0442\u044C
      \u043A\u0430\u043C\u0435\u0440\u0443. \u0421\u043B\u0435\u0434\u0443\u044F
      \u0437\u0430 \u043C\u0430\u0440\u043A\u0435\u0440\u043E\u043C, \u043D\u0430\u0432\u0435\u0434\u0438\u0442\u0435\u0441\u044C
      \u043A\u0430\u043C\u0435\u0440\u043E\u0439 \u043D\u0430 \u0432\u0440\u0430\u0436\u0435\u0441\u043A\u0438\u0439
      \u043E\u0442\u0440\u044F\u0434."
    language: 1
  - text: Use the WASD keys to move the camera. Follow the marker to aim the camera
      at the enemy squad.
    language: 2
