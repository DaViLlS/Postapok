  m_Script: {fileID: 11500000, guid: 0e5a5816d4b94082a5d68d5c7bf86e71, type: 3}
  m_Name: DestroySupplies
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u0423\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0438\u0435 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432"
  titles:
  - text: "\u0423\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u0438\u0435 \u043E\u0431\u044A\u0435\u043A\u0442\u043E\u0432"
    language: 1
  - text: Destruction of objects
    language: 2
  description: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 \u043E\u0431\u044A\u0435\u043A\u0442\u044B,
    \u0443 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0432\u0435\u0440\u0445\u0443
    \u0435\u0441\u0442\u044C \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F,
    \u0447\u0442\u043E\u0431\u044B \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442\u044C
    \u0438\u0445. \u042D\u0442\u043E \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
    \u043B\u0438\u0431\u043E \u0434\u043B\u044F \u043F\u043E\u0431\u0435\u0434\u044B
    \u043D\u0430 \u0443\u0440\u043E\u0432\u043D\u0435, \u043B\u0438\u0431\u043E \u0434\u043B\u044F
    \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u043B\u044C\u043D\u043E\u0439
    \u043D\u0430\u0433\u0440\u0430\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043C\u043E\u0436\u0435\u0442 \u0432\u044B\u043F\u0430\u0441\u0442\u044C \u0438\u0437
    \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u043D\u044B\u0445 \u043E\u0431\u044A\u043A\u0442\u043E\u0432."
  descriptions:
  - text: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 \u043E\u0431\u044A\u0435\u043A\u0442\u044B,
      \u0443 \u043A\u043E\u0442\u043E\u0440\u044B\u0445 \u0441\u0432\u0435\u0440\u0445\u0443
      \u0435\u0441\u0442\u044C \u043F\u043E\u043B\u043E\u0441\u043A\u0430 \u0437\u0434\u043E\u0440\u043E\u0432\u044C\u044F,
      \u0447\u0442\u043E\u0431\u044B \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0438\u0442\u044C
      \u0438\u0445. \u042D\u0442\u043E \u043D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
      \u043B\u0438\u0431\u043E \u0434\u043B\u044F \u043F\u043E\u0431\u0435\u0434\u044B
      \u043D\u0430 \u0443\u0440\u043E\u0432\u043D\u0435, \u043B\u0438\u0431\u043E
      \u0434\u043B\u044F \u043F\u043E\u043B\u0443\u0447\u0435\u043D\u0438\u044F \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u043B\u044C\u043D\u043E\u0439
      \u043D\u0430\u0433\u0440\u0430\u0434\u044B, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
      \u043C\u043E\u0436\u0435\u0442 \u0432\u044B\u043F\u0430\u0441\u0442\u044C \u0438\u0437
      \u0443\u043D\u0438\u0447\u0442\u043E\u0436\u0435\u043D\u043D\u044B\u0445 \u043E\u0431\u044A\u043A\u0442\u043E\u0432."
    language: 1
  - text: Click on objects that have a health bar on top to destroy them. This is
      necessary either to win the level or to receive additional rewards that may
      drop from destroyed objects.
    language: 2
