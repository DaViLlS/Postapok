  m_Script: {fileID: 11500000, guid: 0e5a5816d4b94082a5d68d5c7bf86e71, type: 3}
  m_Name: ResetSquads
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u041E\u0447\u0438\u0441\u0442\u043A\u0430 \u043E\u0442\u0440\u044F\u0434\u043E\u0432"
  titles:
  - text: "\u041E\u0447\u0438\u0441\u0442\u043A\u0430 \u043E\u0442\u0440\u044F\u0434\u043E\u0432"
    language: 1
  - text: Clearing squads
    language: 2
  description: "\u0427\u0442\u043E\u0431\u044B \u0441\u043D\u044F\u0442\u044C \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u0438\u0435
    \u0441 \u043E\u0442\u0440\u044F\u0434\u043E\u0432, \u043F\u0440\u043E\u0441\u0442\u043E
    \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u041B\u041A\u041C \u043F\u043E \u0437\u0435\u043C\u043B\u0435
    \u0438\u043B\u0438 \u043B\u044E\u0431\u043E\u043C\u0443 \u0434\u0440\u0443\u0433\u043E\u043C\u0443
    \u043C\u0435\u0441\u0442\u0443, \u0433\u0434\u0435 \u043D\u0435\u0442 \u043D\u0435\u0436\u0438\u0442\u0438."
  descriptions:
  - text: "\u0427\u0442\u043E\u0431\u044B \u0441\u043D\u044F\u0442\u044C \u0432\u044B\u0434\u0435\u043B\u0435\u043D\u0438\u0435
      \u0441 \u043E\u0442\u0440\u044F\u0434\u043E\u0432, \u043F\u0440\u043E\u0441\u0442\u043E
      \u043D\u0430\u0436\u043C\u0438\u0442\u0435 \u041B\u041A\u041C \u043F\u043E
      \u0437\u0435\u043C\u043B\u0435 \u0438\u043B\u0438 \u043B\u044E\u0431\u043E\u043C\u0443
      \u0434\u0440\u0443\u0433\u043E\u043C\u0443 \u043C\u0435\u0441\u0442\u0443,
      \u0433\u0434\u0435 \u043D\u0435\u0442 \u043D\u0435\u0436\u0438\u0442\u0438."
    language: 1
  - text: To deselect units, simply click on the ground or any other area where there
      are no undead.
    language: 2
