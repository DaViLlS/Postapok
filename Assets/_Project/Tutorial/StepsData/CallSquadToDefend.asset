  m_Name: CallSquadToDefend
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u041F\u0440\u0438\u043A\u0430\u0437 \"\u0417\u0430\u0449\u0438\u0449\u0430\u0442\u044C\""
  titles:
  - text: "\u041F\u0440\u0438\u043A\u0430\u0437 \"\u0417\u0430\u0449\u0438\u0449\u0430\u0442\u044C\""
    language: 1
  - text: The order to "Protect"
    language: 2
  description: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043E\u0442\u0434\u0430\u0442\u044C
    \u043D\u0435\u0436\u0438\u0442\u0438 \u043F\u0440\u0438\u043A\u0430\u0437 \u043D\u0430
    \u0437\u0430\u0449\u0438\u0442\u0443 \u0438\u0433\u0440\u043E\u043A\u0430 \u0438\u043B\u0438
    \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u043C\u0438\u0440\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430. \u0414\u043B\u044F \u044D\u0442\u043E\u0433\u043E
    \u0432\u0430\u043C \u043D\u0443\u0436\u043D\u043E \u043D\u0430\u0436\u0430\u0442\u044C
    \u041F\u041A\u041C \u043F\u043E \u043E\u0431\u044A\u0435\u043A\u0442\u0443 \u0437\u0430\u0449\u0438\u0442\u044B."
  descriptions:
  - text: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u043E\u0442\u0434\u0430\u0442\u044C
      \u043D\u0435\u0436\u0438\u0442\u0438 \u043F\u0440\u0438\u043A\u0430\u0437 \u043D\u0430
      \u0437\u0430\u0449\u0438\u0442\u0443 \u0438\u0433\u0440\u043E\u043A\u0430 \u0438\u043B\u0438
      \u0434\u0440\u0443\u0433\u043E\u0433\u043E \u043C\u0438\u0440\u043D\u043E\u0433\u043E
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u0436\u0430. \u0414\u043B\u044F
      \u044D\u0442\u043E\u0433\u043E \u0432\u0430\u043C \u043D\u0443\u0436\u043D\u043E
      \u043D\u0430\u0436\u0430\u0442\u044C \u041F\u041A\u041C \u043F\u043E \u043E\u0431\u044A\u0435\u043A\u0442\u0443
      \u0437\u0430\u0449\u0438\u0442\u044B."
    language: 1
  - text: You can order the undead to protect a player or another peaceful character.
      To do this, right-click on the protected object.
    language: 2
