  m_Script: {fileID: 11500000, guid: 0e5a5816d4b94082a5d68d5c7bf86e71, type: 3}
  m_Name: BossesAttack
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u041A\u043E\u043D\u0435\u0446?"
  titles:
  - text: "\u041A\u043E\u043D\u0435\u0446?"
    language: 1
  - text: The end?
    language: 2
  description: "\u0412\u044B \u043D\u0435 \u0431\u044B\u043B\u0438 \u0433\u043E\u0442\u043E\u0432\u044B
    \u043A \u0442\u0430\u043A\u043E\u043C\u0443 \u043D\u0430\u043F\u0430\u0434\u0435\u043D\u0438\u044E.
    \u041F\u044F\u0442\u044C \u0437\u0434\u043E\u0440\u043E\u0432\u044B\u0445 \u0431\u0443\u0433\u0430\u0435\u0432
    \u0438\u0434\u0443\u0442 \u043F\u0440\u044F\u043C\u043E \u043D\u0430 \u0432\u0430\u0441.
    \u041F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u043D\u0435\u0438\u0437\u0431\u0435\u0436\u043D\u043E...
    \u041D\u043E \u043D\u0435 \u0441\u0442\u043E\u0438\u0442 \u043E\u0442\u0447\u0430\u0438\u0432\u0430\u0442\u044C\u0441\u044F,
    \u0412\u0441\u0451 \u0435\u0449\u0451 \u0432\u043F\u0435\u0440\u0435\u0434\u0438!"
  descriptions:
  - text: "\u0412\u044B \u043D\u0435 \u0431\u044B\u043B\u0438 \u0433\u043E\u0442\u043E\u0432\u044B
      \u043A \u0442\u0430\u043A\u043E\u043C\u0443 \u043D\u0430\u043F\u0430\u0434\u0435\u043D\u0438\u044E.
      \u041F\u044F\u0442\u044C \u0437\u0434\u043E\u0440\u043E\u0432\u044B\u0445 \u0431\u0443\u0433\u0430\u0435\u0432
      \u0438\u0434\u0443\u0442 \u043F\u0440\u044F\u043C\u043E \u043D\u0430 \u0432\u0430\u0441.
      \u041F\u043E\u0440\u0430\u0436\u0435\u043D\u0438\u0435 \u043D\u0435\u0438\u0437\u0431\u0435\u0436\u043D\u043E...
      \u041D\u043E \u043D\u0435 \u0441\u0442\u043E\u0438\u0442 \u043E\u0442\u0447\u0430\u0438\u0432\u0430\u0442\u044C\u0441\u044F,
      \u0412\u0441\u0451 \u0435\u0449\u0451 \u0432\u043F\u0435\u0440\u0435\u0434\u0438!"
    language: 1
  - text: You weren't prepared for this attack. Five big, strong guys are coming
      right at you. Defeat is inevitable... But don't despair, there's still hope!
    language: 2
