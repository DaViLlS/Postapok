  title: "\u0421\u0432\u043E\u0431\u043E\u0434\u043D\u0430\u044F \u043A\u0430\u043C\u0435\u0440\u0430"
  titles:
  - text: "\u0421\u0432\u043E\u0431\u043E\u0434\u043D\u0430\u044F \u043A\u0430\u043C\u0435\u0440\u0430"
    language: 1
  - text: A free camera
    language: 2
  description: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u041F\u0440\u043E\u0431\u0435\u043B,
    \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0446\u0435\u043F\u0438\u0442\u044C
    \u043A\u0430\u043C\u0435\u0440\u0443 \u0434\u043B\u044F \u0435\u0451 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0433\u043E
    \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u044F."
  descriptions:
  - text: "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u041F\u0440\u043E\u0431\u0435\u043B,
      \u0447\u0442\u043E\u0431\u044B \u043E\u0442\u0446\u0435\u043F\u0438\u0442\u044C
      \u043A\u0430\u043C\u0435\u0440\u0443 \u0434\u043B\u044F \u0435\u0451 \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E\u0433\u043E
      \u043F\u0435\u0440\u0435\u043C\u0435\u0449\u0435\u043D\u0438\u044F."
    language: 1
  - text: Press the Spacebar to detach the camera so that it can move freely.
    language: 2
