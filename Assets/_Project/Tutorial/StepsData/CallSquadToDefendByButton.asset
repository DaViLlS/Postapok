  m_Name: CallSquadToDefendByButton
  m_EditorClassIdentifier: Assembly-CSharp::_Project.Tutorial.Scripts.StepData
  title: "\u0411\u044B\u0441\u0442\u0440\u044B\u0439 \u043F\u0440\u0438\u043A\u0430\u0437
    \"\u0417\u0430\u0449\u0438\u0449\u0430\u0442\u044C\""
  titles:
  - text: "\u0411\u044B\u0441\u0442\u0440\u044B\u0439 \u043F\u0440\u0438\u043A\u0430\u0437
      \"\u0417\u0430\u0449\u0438\u0449\u0430\u0442\u044C\""
    language: 1
  - text: Quick order to "Protect"
    language: 2
  description: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0431\u044B\u0441\u0442\u0440\u043E
    \u043E\u0442\u0434\u0430\u0442\u044C \u043F\u0440\u0438\u043A\u0430\u0437 \u0432\u044B\u0431\u0440\u0430\u043D\u043D\u043E\u043C\u0443
    \u043E\u0442\u0440\u044F\u0434\u0443 \u043D\u0430 \u0432\u0430\u0448\u0443 \u0437\u0430\u0449\u0438\u0442\u0443.
    \u041D\u0430\u0436\u043C\u0438\u0442\u0435 \u043D\u0430 \u043A\u043B\u0430\u0432\u0438\u0448\u0443
    'T' \u0438 \u043D\u0435\u0436\u0438\u0442\u044C \u043E\u0442\u043A\u043B\u0438\u043A\u043D\u0435\u0442\u0441\u044F
    \u043D\u0430 \u0432\u0430\u0448 \u043F\u0440\u0438\u043A\u0430\u0437."
  descriptions:
  - text: "\u0412\u044B \u043C\u043E\u0436\u0435\u0442\u0435 \u0431\u044B\u0441\u0442\u0440\u043E
      \u043E\u0442\u0434\u0430\u0442\u044C \u043F\u0440\u0438\u043A\u0430\u0437 \u0432\u044B\u0431\u0440\u0430\u043D\u043D\u043E\u043C\u0443
      \u043E\u0442\u0440\u044F\u0434\u0443 \u043D\u0430 \u0432\u0430\u0448\u0443
      \u0437\u0430\u0449\u0438\u0442\u0443. \u041D\u0430\u0436\u043C\u0438\u0442\u0435
      \u043D\u0430 \u043A\u043B\u0430\u0432\u0438\u0448\u0443 'T' \u0438 \u043D\u0435\u0436\u0438\u0442\u044C
      \u043E\u0442\u043A\u043B\u0438\u043A\u043D\u0435\u0442\u0441\u044F \u043D\u0430
      \u0432\u0430\u0448 \u043F\u0440\u0438\u043A\u0430\u0437."
    language: 1
  - text: You can quickly order a selected unit to defend you. Press the 'T' key
      and the undead will respond to your command.
    language: 2
