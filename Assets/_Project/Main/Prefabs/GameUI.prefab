  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u041F\u0440\u0438\u0432\u0435\u0442 \u0435\u043F\u0442\u0430 \u0442\u0443\u0442
    \u043F\u043E\u043C\u043E\u0449\u044C \u0442\u0432\u043E\u044F \u043D\u0443\u0436\u043D\u0430.
    \u041A\u0443\u043B\u044C\u0442\u0438\u0441\u0442\u044B \u043D\u0430\u0441\u0440\u0430\u043B\u0438
    \u0438 \u0442\u0435\u0431\u0435 \u043D\u0430\u0434\u043E \u0443\u0431\u0440\u0430\u0442\u044C
    \u0437\u0430 \u043D\u0438\u043C\u0438. \u0421\u0430\u043C \u044F \u043D\u0435
    \u043C\u043E\u0433\u0443, \u043D\u0435 \u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043E
    \u043F\u043E \u0434\u043E\u043B\u0436\u043D\u043E\u0441\u0442\u0438. \u0420\u0430\u0431\u043E\u0442\u0430
    \u043F\u0440\u044F\u043C \u0434\u043B\u044F \u0442\u0435\u0431\u044F, \u043A\u043E\u043F\u0430\u0442\u0435\u043B\u044C
    \u043C\u043E\u0433\u0438\u043B \u0441\u0440\u0430\u043D\u044B\u0439. \u0410 \u044F
    \u0442\u0435\u0431\u0435 \u0448\u043E\u043A\u043E\u043B\u0430\u0434\u043A\u0443
    \u0434\u0430\u043C \u0437\u0430 \u044D\u0442\u043E. \u0421 \u043E\u0440\u0435\u0448\u043A\u0430\u043C\u0438."
  m_isRightToLeft: 0
